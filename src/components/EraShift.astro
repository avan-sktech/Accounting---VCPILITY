</style>

<script>
function initEraShift() {
    const wrapper = document.getElementById('era-shift');
    const sticky = document.getElementById('era-sticky');
    if (!wrapper || !sticky) return;

    const bgOld = document.getElementById('era-bg-old');
    const bgNew = document.getElementById('era-bg-new');
    const burst = document.getElementById('era-burst');
    const act1 = document.getElementById('era-act1');
    const act3 = document.getElementById('era-act3');
    const text1 = document.getElementById('era-text-1');
    const text2 = document.getElementById('era-text-2');
    const text3 = document.getElementById('era-text-3');
    const progressBar = document.getElementById('era-progress-bar');
    const particlesContainer = document.getElementById('era-particles');

    // Mobius elements
    const canvas = document.getElementById('mobius-canvas');
    const ctx = canvas.getContext('2d');
    const CW = 600, CH = 380;
    const panels = [0,1,2,3].map(i => document.getElementById(`mf-panel-${i}`));
    const centerLabel = document.getElementById('mf-center-label');
    const centerPhrases = ['Your practice. Running itself.', 'Every client. Accounted for.', 'Every opportunity. Captured.', 'Growth without the grind.'];

    // SVG stroke init
    function initStrokes(svg, cls) {
        if (!svg) return;
        svg.querySelectorAll('.' + cls).forEach(el => {
            const len = el.getTotalLength ? el.getTotalLength() : 500;
            el.style.setProperty('--dash-length', len);
            el.style.strokeDasharray = len;
            el.style.strokeDashoffset = len;
        });
    }
    const ledgerSvg = document.getElementById('era-ledger');
    initStrokes(ledgerSvg, 'ledger-line');

    // Particles
    const PARTICLE_COUNT = 50;
    const particles = [];
    for (let i = 0; i < PARTICLE_COUNT; i++) {
        const el = document.createElement('div');
        el.className = 'era-particle';
        const startX = 30 + Math.random() * 35;
        const startY = 20 + Math.random() * 60;
        const angle = Math.random() * Math.PI * 2;
        const dist = 20 + Math.random() * 35;
        const scatterX = 50 + Math.cos(angle) * dist;
        const scatterY = 50 + Math.sin(angle) * dist;
        const endX = 50 + (Math.random() - 0.5) * 30;
        const endY = 50 + (Math.random() - 0.5) * 20;
        const size = 2 + Math.random() * 4;
        el.style.width = size + 'px';
        el.style.height = size + 'px';
        particlesContainer.appendChild(el);
        particles.push({ el, startX, startY, scatterX, scatterY, endX, endY });
    }

    // Helpers
    function clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }
    function map(v, a, b, c, d) { return c + (clamp(v,a,b)-a)/(b-a)*(d-c); }
    function smoothstep(t) { return t*t*(3-2*t); }
    function lerp(a, b, t) { return a + (b-a)*t; }

    // ═══ MOBIUS STRIP RENDERER ═══
    function mobiusXYZ(u, v) {
        const R = 2.2, hw = 0.55;
        const x = (R + v*hw*Math.cos(u*0.5)) * Math.cos(u);
        const y = (R + v*hw*Math.cos(u*0.5)) * Math.sin(u);
        const z = v*hw*Math.sin(u*0.5);
        return [x, y, z];
    }

    function project(x, y, z, rotY) {
        const cosY = Math.cos(rotY), sinY = Math.sin(rotY);
        let rx = x*cosY + z*sinY, rz = -x*sinY + z*cosY, ry = y;
        const tilt = 0.36, cosT = Math.cos(tilt), sinT = Math.sin(tilt);
        let ty = ry*cosT - rz*sinT, tz = ry*sinT + rz*cosT;
        const fov = 6.0, depth = tz + fov + 0.5, sc = fov/depth*100;
        return [CW*0.5 + rx*sc, CH*0.5 + ty*sc, depth];
    }

    const U_STEPS = 120, V_STEPS = 14;
    let mobiusRotY = 0, scanPhase = 0, autoTime = 0, lastT = 0;
    let currentMobiusFeature = 0;
    const featureAngles = [0, Math.PI*0.5, Math.PI, Math.PI*1.5];

    function drawMobius(rotY, t) {
        ctx.clearRect(0, 0, CW, CH);
        const col = { edge: [0,210,255], grid: [60,160,220], goldEdge: [201,168,76], particle: [220,200,100] };
        const faces = [];

        for (let i = 0; i < U_STEPS; i++) {
            const u0 = (i/U_STEPS)*Math.PI*2, u1 = ((i+1)/U_STEPS)*Math.PI*2;
            const avgU = (u0+u1)*0.5;
            for (let j = 0; j < V_STEPS; j++) {
                const v0 = -1 + (j/V_STEPS)*2, v1 = -1 + ((j+1)/V_STEPS)*2;
                const pts = [[u0,v0],[u1,v0],[u1,v1],[u0,v1]].map(([u,v]) => {
                    const [x,y,z] = mobiusXYZ(u,v);
                    return project(x,y,z,rotY);
                });
                const ex = pts[1][0]-pts[0][0], ey = pts[1][1]-pts[0][1];
                const fx = pts[3][0]-pts[0][0], fy = pts[3][1]-pts[0][1];
                if (ex*fy - ey*fx > 0) continue;
                const avgDepth = (pts[0][2]+pts[1][2]+pts[2][2]+pts[3][2])*0.25;
                const fA = featureAngles[currentMobiusFeature];
                const dist = Math.min(Math.abs(avgU-fA), Math.PI*2-Math.abs(avgU-fA));
                const hi = Math.max(0, 1-dist/1.5);
                const scanU = ((scanPhase%(Math.PI*2))+Math.PI*2)%(Math.PI*2);
                const scanDist = Math.min(Math.abs(avgU-scanU), Math.PI*2-Math.abs(avgU-scanU));
                const scan = Math.max(0, 1-scanDist/0.35)*0.6;
                const vMid = Math.abs((v0+v1)*0.5);
                const isEdge = vMid > 0.75;
                faces.push({ pts, avgDepth, hi, scan, isEdge, vMid });
            }
        }
        faces.sort((a,b) => b.avgDepth - a.avgDepth);

        for (const f of faces) {
            const [p0,p1,p2,p3] = f.pts;
            ctx.beginPath(); ctx.moveTo(p0[0],p0[1]); ctx.lineTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.lineTo(p3[0],p3[1]); ctx.closePath();
            const fa = 0.03 + f.hi*0.12 + f.scan*0.08;
            let fr,fg,fb;
            if (f.hi > 0.1) { fr=Math.round(col.grid[0]*(1-f.hi)+col.goldEdge[0]*f.hi); fg=Math.round(col.grid[1]*(1-f.hi)+col.goldEdge[1]*f.hi); fb=Math.round(col.grid[2]*(1-f.hi)+col.goldEdge[2]*f.hi); }
            else { [fr,fg,fb] = col.grid; }
            ctx.fillStyle = `rgba(${fr},${fg},${fb},${fa.toFixed(3)})`; ctx.fill();

            const la = f.isEdge ? (0.55+f.hi*0.4+f.scan*0.3) : (0.12+f.hi*0.25+f.scan*0.2);
            let lr,lg,lb;
            if (f.isEdge) { if (f.hi>0.15) { lr=Math.round(col.edge[0]*0.3+col.goldEdge[0]*0.7); lg=Math.round(col.edge[1]*0.3+col.goldEdge[1]*0.7); lb=Math.round(col.edge[2]*0.3+col.goldEdge[2]*0.7); } else { [lr,lg,lb]=col.edge; } }
            else { [lr,lg,lb]=col.grid; }
            ctx.strokeStyle = `rgba(${lr},${lg},${lb},${Math.min(1,la).toFixed(3)})`; ctx.lineWidth = f.isEdge ? (1.8+f.hi*1.2) : 0.6;
            ctx.beginPath(); ctx.moveTo(p0[0],p0[1]); ctx.lineTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.lineTo(p3[0],p3[1]); ctx.closePath(); ctx.stroke();
        }

        // Edge glow
        for (const f of faces) {
            if (!f.isEdge) continue;
            const [p0,p1,p2,p3] = f.pts;
            const gs = 0.18+f.hi*0.35+f.scan*0.25;
            const [gr,gg,gb] = f.hi > 0.1 ? col.goldEdge : [0,180,255];
            ctx.beginPath(); ctx.moveTo(p0[0],p0[1]); ctx.lineTo(p1[0],p1[1]); ctx.moveTo(p3[0],p3[1]); ctx.lineTo(p2[0],p2[1]);
            ctx.strokeStyle = `rgba(${gr},${gg},${gb},${(gs*0.4).toFixed(3)})`; ctx.lineWidth = 6; ctx.stroke();
            ctx.strokeStyle = `rgba(${gr},${gg},${gb},${(gs*0.2).toFixed(3)})`; ctx.lineWidth = 12; ctx.stroke();
        }

        // Feature highlight particles
        const fA = featureAngles[currentMobiusFeature];
        for (let k = 0; k < 10; k++) {
            const u = fA + (k-5)*0.12;
            const [x,y,z] = mobiusXYZ(u, 1.0);
            const [px,py] = project(x,y,z,rotY);
            const al = Math.max(0, 1-Math.abs(k-5)/6)*0.9;
            ctx.beginPath(); ctx.arc(px,py,3,0,Math.PI*2);
            ctx.fillStyle = `rgba(201,168,76,${(al*0.9).toFixed(3)})`; ctx.fill();
            ctx.beginPath(); ctx.arc(px,py,9,0,Math.PI*2);
            ctx.fillStyle = `rgba(201,168,76,${(al*0.15).toFixed(3)})`; ctx.fill();
        }

        // Center glow
        const g = ctx.createRadialGradient(CW*0.5, CH*0.55, 20, CW*0.5, CH*0.55, 220);
        g.addColorStop(0, 'rgba(0,180,255,0.045)');
        g.addColorStop(0.5, 'rgba(80,50,180,0.025)');
        g.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = g; ctx.fillRect(0,0,CW,CH);
    }

    // Mobius animation loop
    let mobiusActive = false;
    let mobiusProgress = 0; // 0-1 within the mobius section

    function animateMobius(t) {
        if (!mobiusActive) return;
        const dt = (t - lastT)/1000; lastT = t; autoTime += dt;
        scanPhase += dt * 0.85;

        // Determine which feature to show based on mobiusProgress
        const featureIdx = Math.min(3, Math.floor(mobiusProgress * 4));
        if (featureIdx !== currentMobiusFeature) {
            currentMobiusFeature = featureIdx;
            centerLabel.textContent = centerPhrases[featureIdx];
        }

        // Show/hide panels
        panels.forEach((p, i) => {
            if (i === featureIdx) p.classList.add('visible');
            else p.classList.remove('visible');
        });

        // Rotate mobius based on progress
        const targetR = mobiusProgress * Math.PI * 2;
        mobiusRotY += (targetR - mobiusRotY) * 0.06;
        const driftY = mobiusRotY + Math.sin(autoTime * 0.18) * 0.04;

        drawMobius(driftY, autoTime);
        requestAnimationFrame(animateMobius);
    }

    // ═══ SCROLL HANDLER ═══
    let ticking = false;
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }

    function update() {
        ticking = false;
        const rect = wrapper.getBoundingClientRect();
        const wrapperHeight = wrapper.offsetHeight - window.innerHeight;
        const scrolled = -rect.top;
        const progress = clamp(scrolled / wrapperHeight, 0, 1);

        progressBar.style.width = (progress * 100) + '%';

        // ── ACT 1: 0 → 0.2 (Ledger draws in) ──
        const a1p = map(progress, 0, 0.2, 0, 1);
        const a1s = smoothstep(a1p);
        if (ledgerSvg) {
            ledgerSvg.querySelectorAll('.ledger-line').forEach(el => {
                const len = parseFloat(el.style.getPropertyValue('--dash-length')) || 500;
                el.style.strokeDashoffset = len * (1 - a1s);
            });
        }
        const ledgerFade = map(progress, 0.18, 0.3, 1, 0);
        if (act1) act1.style.opacity = Math.min(a1p < 0.05 ? map(progress, 0, 0.02, 0, 1) : 1, ledgerFade);

        // Text 1
        const t1In = smoothstep(map(progress, 0.03, 0.1, 0, 1));
        const t1Out = smoothstep(map(progress, 0.17, 0.22, 1, 0));
        text1.style.opacity = Math.min(t1In, t1Out);
        text1.style.transform = `translateY(${(1-t1In)*30}px)`;
        text1.style.filter = `blur(${(1-t1In)*6}px)`;

        // ── ACT 2: 0.2 → 0.4 (Dissolution + That era is over) ──
        bgOld.style.opacity = map(progress, 0.18, 0.35, 1, 0);
        bgNew.style.opacity = map(progress, 0.25, 0.38, 0, 1);

        const burstSize = map(progress, 0.24, 0.35, 0, 120);
        const burstOp = progress < 0.32 ? map(progress, 0.24, 0.32, 0, 1) : map(progress, 0.35, 0.4, 1, 0);
        burst.style.width = burstSize + 'vh'; burst.style.height = burstSize + 'vh'; burst.style.opacity = burstOp;

        const t2In = smoothstep(map(progress, 0.26, 0.32, 0, 1));
        const t2Out = smoothstep(map(progress, 0.37, 0.42, 1, 0));
        text2.style.opacity = Math.min(t2In, t2Out);
        const t2Scale = lerp(0.85, 1.1, smoothstep(map(progress, 0.26, 0.38, 0, 1)));
        text2.style.transform = `translate(-50%, -50%) scale(${t2Scale})`;

        // ── PARTICLES ──
        particles.forEach(p => {
            let px, py, op;
            if (progress < 0.18) { px = p.startX; py = p.startY; op = map(progress, 0.1, 0.18, 0, 0.4); }
            else if (progress < 0.32) { const t = smoothstep(map(progress, 0.18, 0.32, 0, 1)); px = lerp(p.startX, p.scatterX, t); py = lerp(p.startY, p.scatterY, t); op = 0.3+t*0.7; }
            else if (progress < 0.45) { const t = smoothstep(map(progress, 0.32, 0.45, 0, 1)); px = lerp(p.scatterX, p.endX, t); py = lerp(p.scatterY, p.endY, t); op = 1; }
            else { px = p.endX; py = p.endY; op = map(progress, 0.45, 0.55, 1, 0); }
            p.el.style.left = px+'%'; p.el.style.top = py+'%'; p.el.style.opacity = clamp(op,0,1);
        });

        // ── ACT 3: 0.4 → 0.95 (Mobius strip + features) ──
        const mobiusIn = map(progress, 0.38, 0.45, 0, 1);
        const mobiusOut = map(progress, 0.92, 0.98, 1, 0);
        const mobiusOpacity = Math.min(mobiusIn, mobiusOut);
        act3.style.opacity = mobiusOpacity;

        // Mobius progress within its section (0.45 to 0.9)
        mobiusProgress = clamp(map(progress, 0.45, 0.9, 0, 1), 0, 0.999);

        // Start/stop mobius animation
        if (mobiusOpacity > 0 && !mobiusActive) {
            mobiusActive = true; lastT = performance.now();
            requestAnimationFrame(animateMobius);
        } else if (mobiusOpacity <= 0) {
            mobiusActive = false;
        }

        // Text 3
        const t3In = smoothstep(map(progress, 0.42, 0.5, 0, 1));
        const t3Out = smoothstep(map(progress, 0.9, 0.95, 1, 0));
        text3.style.opacity = Math.min(t3In, t3Out);
        text3.style.transform = `translateY(${(1-t3In)*30}px)`;
        text3.style.filter = `blur(${(1-t3In)*5}px)`;

        // Final fade
        sticky.style.opacity = map(progress, 0.96, 1, 1, 0);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    update();
}

document.addEventListener('DOMContentLoaded', initEraShift);
</script>
