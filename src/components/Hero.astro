<!-- ═══ HERO — Full Landing Page Slider ═══ -->
<!-- Uses site fonts: Fraunces (serif) + Space Grotesk (sans) -->

<section class="hero" id="heroSection">
    <div class="hero-bg" id="heroBg"></div>
    <div class="hero-grid"></div>
    <div class="hero-orb" id="heroOrb"></div>

    <div class="hero-content">
        <div class="hero-text active" id="heroText">
            <div class="hero-badge" id="heroBadge">
                <span class="hero-badge-dot" id="badgeDot"></span>
                <span id="badgeText"></span>
            </div>
            <h1 class="hero-h1"><span id="h1Main"></span><em id="h1Accent"></em></h1>
            <p class="hero-sub" id="heroSub"></p>
            <p class="hero-support" id="heroSupport"></p>
            <div class="hero-ctas">
                <button class="cta-p" id="ctaP" onclick="window.location='/demo'"></button>
                <button class="cta-s" id="ctaS" onclick="window.location='/features'"></button>
            </div>
        </div>

        <div class="hero-visual active" id="heroVisual">
            <div class="dash-mock">
                <div class="dash-titlebar">
                    <span class="dash-dot" style="background:#FF5F57"></span>
                    <span class="dash-dot" style="background:#FFBD2E"></span>
                    <span class="dash-dot" style="background:#28CA42"></span>
                    <span style="flex:1"></span>
                    <span style="font-size:11px;color:rgba(226,232,240,0.35)">VCPility Dashboard</span>
                </div>
                <div class="dash-body" id="dashBody"></div>
            </div>
        </div>
    </div>

    <div class="hero-nav">
        <button class="h-arrow" id="heroPrev" aria-label="Previous">&#8592;</button>
        <div class="h-dots" id="heroDots"></div>
        <button class="h-arrow" id="heroNext" aria-label="Next">&#8594;</button>
    </div>
    <div class="hero-labels" id="heroLabels"></div>
    <div class="hero-counter" id="heroCounter"></div>
</section>

<style is:global>
    .hero{position:relative;min-height:100vh;overflow:hidden}
    .hero-bg{position:absolute;inset:0;transition:background 1.2s ease}
    .hero-grid{
        position:absolute;inset:0;
        background-image:linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px);
        background-size:72px 72px;opacity:0.5;
    }
    .hero-orb{
        position:absolute;top:10%;right:5%;width:400px;height:400px;
        border-radius:50%;filter:blur(80px);
        transition:background 1.2s;animation:heroFloat 10s ease-in-out infinite;pointer-events:none;
    }
    @keyframes heroFloat{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-25px) scale(1.04)}}

    .hero-content{
        position:relative;z-index:2;max-width:1300px;margin:0 auto;
        display:grid;grid-template-columns:1fr 440px;align-items:center;
        padding:150px 52px 100px;gap:48px;min-height:100vh;
    }

    /* Text animations */
    .hero-text{opacity:0;transform:translateY(28px);transition:all 0.65s cubic-bezier(0.22,1,0.36,1)}
    .hero-text.active{opacity:1;transform:translateY(0)}
    .hero-text.exiting{opacity:0;transform:translateY(-16px);transition:all 0.35s ease}

    .hero-badge{
        display:inline-flex;align-items:center;gap:9px;
        padding:6px 18px;border-radius:100px;margin-bottom:28px;
        font-size:11px;font-weight:600;letter-spacing:0.1em;
        font-family:'Space Grotesk',sans-serif;
        transition:all 0.4s;
    }
    .hero-badge-dot{width:6px;height:6px;border-radius:50%;animation:heroPulse 2.5s ease-in-out infinite}
    @keyframes heroPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.6;transform:scale(1.4)}}

    .hero-h1{
        font-family:'Fraunces',Georgia,serif;font-size:54px;font-weight:400;
        line-height:1.08;color:#F8FAFC;margin-bottom:22px;
        letter-spacing:-0.02em;max-width:640px;
    }
    .hero-h1 em{font-style:italic;transition:color 0.4s}
    .hero-sub{font-size:17px;line-height:1.72;color:rgba(226,232,240,0.55);max-width:560px;margin-bottom:10px;font-family:'Space Grotesk',sans-serif}
    .hero-support{font-size:13px;color:rgba(226,232,240,0.35);margin-bottom:36px;font-family:'Space Grotesk',sans-serif}
    .hero-ctas{display:flex;gap:14px;flex-wrap:wrap}
    .cta-p{
        padding:15px 34px;border-radius:9px;border:none;
        color:#fff;font-size:15px;font-weight:600;font-family:'Space Grotesk',sans-serif;
        cursor:pointer;transition:all 0.35s cubic-bezier(0.22,1,0.36,1);
    }
    .cta-p:hover{transform:translateY(-2px);filter:brightness(1.12)}
    .cta-s{
        padding:15px 28px;border-radius:9px;
        border:1px solid rgba(255,255,255,0.12);
        background:rgba(255,255,255,0.03);color:rgba(226,232,240,0.55);
        font-size:15px;font-weight:500;font-family:'Space Grotesk',sans-serif;cursor:pointer;transition:all 0.3s;
    }
    .cta-s:hover{background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.25)}

    /* Dashboard mock */
    .hero-visual{
        opacity:0;transform:translateY(24px) scale(0.97);
        transition:all 0.7s cubic-bezier(0.22,1,0.36,1) 0.12s;
    }
    .hero-visual.active{opacity:1;transform:translateY(0) scale(1)}
    .hero-visual.exiting{opacity:0;transform:translateY(-14px) scale(0.97);transition:all 0.35s ease}

    .dash-mock{
        background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);
        border-radius:20px;overflow:hidden;position:relative;
    }
    .dash-titlebar{
        display:flex;align-items:center;gap:6px;
        padding:12px 16px;background:rgba(255,255,255,0.02);border-bottom:1px solid rgba(255,255,255,0.07);
    }
    .dash-dot{width:8px;height:8px;border-radius:50%}
    .dash-body{padding:20px}
    .dash-stat-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
    .dash-stat-card{
        background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);
        border-radius:12px;padding:16px;
    }
    .dash-stat-label{font-size:11px;color:rgba(226,232,240,0.35);letter-spacing:0.06em;margin-bottom:6px;font-family:'Space Grotesk',sans-serif}
    .dash-stat-val{font-size:28px;font-weight:700;font-family:'Space Grotesk',sans-serif;letter-spacing:-0.03em}
    .dash-chart{
        background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);
        border-radius:12px;padding:16px;height:120px;position:relative;overflow:hidden;
    }
    .dash-chart-label{font-size:11px;color:rgba(226,232,240,0.35);letter-spacing:0.06em;margin-bottom:12px;font-family:'Space Grotesk',sans-serif}
    .dash-bars{display:flex;align-items:flex-end;gap:6px;height:72px}
    .dash-bar{
        flex:1;border-radius:4px 4px 0 0;
        animation:barGrow 1.2s cubic-bezier(0.22,1,0.36,1) both;
    }
    @keyframes barGrow{from{height:0}to{height:var(--h)}}

    /* Navigation */
    .hero-nav{
        position:absolute;bottom:40px;left:0;right:0;z-index:4;
        display:flex;align-items:center;justify-content:center;gap:24px;
    }
    .h-arrow{
        width:40px;height:40px;border-radius:50%;
        border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.03);
        color:rgba(255,255,255,0.5);cursor:pointer;display:flex;align-items:center;
        justify-content:center;font-size:16px;transition:all 0.3s;
    }
    .h-arrow:hover{background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.8)}
    .h-dots{display:flex;gap:6px;align-items:center}
    .h-dot{
        height:10px;border-radius:5px;border:none;cursor:pointer;
        transition:all 0.45s cubic-bezier(0.22,1,0.36,1);padding:0;position:relative;overflow:hidden;
    }
    .h-dot-off{width:10px;background:rgba(255,255,255,0.12)}
    .h-dot-off:hover{background:rgba(255,255,255,0.25)}
    .h-dot-on{width:48px}
    .h-dot-prog{
        position:absolute;top:0;left:0;height:100%;border-radius:5px;
        background:rgba(255,255,255,0.3);
    }
    .h-dot-prog-run{animation:heroProgFill 7s linear forwards}
    @keyframes heroProgFill{from{width:0}to{width:100%}}

    .hero-counter{
        position:absolute;bottom:44px;right:52px;z-index:4;
        font-size:12px;color:rgba(255,255,255,0.22);letter-spacing:0.06em;
        font-family:'Space Grotesk',sans-serif;
    }
    .hero-labels{
        position:absolute;bottom:60px;left:0;right:0;z-index:4;
        display:flex;justify-content:center;gap:4px;
    }
    .hero-label{
        font-size:10px;letter-spacing:0.06em;font-weight:500;
        color:rgba(255,255,255,0.22);cursor:pointer;padding:4px 8px;
        border:none;background:none;font-family:'Space Grotesk',sans-serif;transition:color 0.3s;white-space:nowrap;
    }
    .hero-label.act{color:rgba(255,255,255,0.65)}
    .hero-label:hover{color:rgba(255,255,255,0.45)}

    @media(max-width:1024px){
        .hero-content{grid-template-columns:1fr;padding:120px 28px 80px;gap:32px}
        .hero-visual{order:-1}
        .hero-h1{font-size:36px}
        .hero-labels{display:none}
    }
    @media(max-width:600px){
        .hero-content{padding:100px 20px 80px}
    }
</style>

<script is:inline>
(function(){
    var SL=[
        {id:"u1",label:"GROWTH",badge:"THE GROWTH ENGINE FOR AUSTRALIAN PRACTICES",
         h1:"Your next client is searching right now. ",h1a:"Will they find you?",
         sub:"VCPility is an AI-powered growth and client acquisition engine built exclusively for Australian accounting, taxation and bookkeeping practices.",
         sup:"No lock-in contracts. Operational within days. One fixed monthly fee.",
         cta:"Book a Growth Consultation",cta2:"See How It Works \u2192",
         accent:"#0D9488",grad:"rgba(13,148,136,0.15)",
         dash:{s1:{l:"NEW ENQUIRIES",v:"47"},s2:{l:"BOOKED THIS WEEK",v:"12"},
           bars:[65,40,80,55,90,70,85,45,75,60,88,72],barC:"#0D9488"}},
        {id:"u2",label:"PLATFORM",badge:"ONE PLATFORM REPLACES FIVE SEPARATE TOOLS",
         h1:"One platform. One team. One fee. ",h1a:"More clients.",
         sub:"Website, CRM, AI agents, SEO, advertising, reputation management and social media \u2014 all managed for you under a single monthly subscription.",
         sup:"Replaces your website host, email tool, CRM, review manager, social scheduler and SEO agency.",
         cta:"See Pricing",cta2:"Book a Growth Consultation \u2192",
         accent:"#6366F1",grad:"rgba(99,102,241,0.15)",
         dash:{s1:{l:"TOOLS REPLACED",v:"6"},s2:{l:"MONTHLY SAVING",v:"70%"},
           bars:[30,70,45,85,60,90,50,75,65,80,55,88],barC:"#6366F1"}},
        {id:"tax",label:"TAX AGENTS",badge:"BUILT FOR TAX AGENTS",
         h1:"Tax season should build your practice ",h1a:"\u2014 not break your team.",
         sub:"AI agents qualify enquiries before they reach your desk. Automated follow-ups keep your pipeline warm year-round. Your team focuses on lodgements.",
         sup:"BAS, payroll tax, TPAR, STP \u2014 your calendar is full. Let VCPility run growth in the background.",
         cta:"Book a Tax Agent Consultation",cta2:"See Tax Agent Features \u2192",
         accent:"#F59E0B",grad:"rgba(245,158,11,0.12)",
         dash:{s1:{l:"LEADS QUALIFIED",v:"34"},s2:{l:"BAS ON TRACK",v:"98%"},
           bars:[50,75,90,65,80,40,70,85,55,60,78,92],barC:"#F59E0B"}},
        {id:"acc",label:"ACCOUNTANTS",badge:"BUILT FOR ACCOUNTING PRACTICES",
         h1:"The practices that thrive won\u2019t just be technically excellent. ",h1a:"They\u2019ll be operationally unmatched.",
         sub:"Attract high-value advisory clients through targeted visibility, Answer Engine Optimisation and a StoryBrand website that positions your firm for growth.",
         sup:"68% of accountants report unsustainable workloads. VCPility automates the non-billable work.",
         cta:"Book an Advisory Growth Consultation",cta2:"See Accountant Features \u2192",
         accent:"#0EA5E9",grad:"rgba(14,165,233,0.15)",
         dash:{s1:{l:"ADVISORY LEADS",v:"23"},s2:{l:"CONVERSION RATE",v:"38%"},
           bars:[60,45,72,88,55,80,65,90,48,76,82,68],barC:"#0EA5E9"}},
        {id:"bk",label:"BOOKKEEPERS",badge:"BUILT FOR BOOKKEEPERS",
         h1:"Your bookkeeping practice deserves more than ",h1a:"Gumtree leads and word of mouth.",
         sub:"A professional growth system that brings consistent, qualified clients every month \u2014 without cold calls, networking events or paid advertising you manage yourself.",
         sup:"Stop chasing documents. Stop competing on price. Start growing predictably.",
         cta:"Book a Bookkeeper Consultation",cta2:"See Bookkeeper Features \u2192",
         accent:"#EC4899",grad:"rgba(236,72,153,0.12)",
         dash:{s1:{l:"MONTHLY CLIENTS",v:"+9"},s2:{l:"DOCS AUTO-SENT",v:"87%"},
           bars:[40,60,55,78,85,50,72,68,90,62,80,45],barC:"#EC4899"}},
    ];

    var cur=0,busy=false,paused=false,timer=null;
    var $=function(id){return document.getElementById(id)};

    function renderDash(d,c){
        var h='<div class="dash-stat-row">'+
            '<div class="dash-stat-card"><div class="dash-stat-label">'+d.s1.l+'</div><div class="dash-stat-val" style="color:'+c+'">'+d.s1.v+'</div></div>'+
            '<div class="dash-stat-card"><div class="dash-stat-label">'+d.s2.l+'</div><div class="dash-stat-val" style="color:'+c+'">'+d.s2.v+'</div></div>'+
            '</div><div class="dash-chart"><div class="dash-chart-label">CLIENT ACQUISITION TREND</div><div class="dash-bars">';
        d.bars.forEach(function(b,i){
            h+='<div class="dash-bar" style="--h:'+b+'%;height:var(--h);background:'+d.barC+';opacity:'+(0.4+i*0.05)+';animation-delay:'+i*60+'ms"></div>';
        });
        h+='</div></div>';
        $("dashBody").innerHTML=h;
    }

    function applySlide(){
        var s=SL[cur];
        $("heroBg").style.background='radial-gradient(ellipse 80% 60% at 70% 40%,'+s.grad+',transparent 70%),radial-gradient(ellipse 50% 80% at 20% 80%,rgba(13,148,136,0.04),transparent 60%),linear-gradient(180deg,#060A14 0%,#0D1225 50%,#060A14 100%)';
        $("heroOrb").style.background='radial-gradient(circle,'+s.accent+'18,transparent 70%)';
        $("heroBadge").style.cssText='border:1px solid '+s.accent+'40;background:'+s.accent+'10;display:inline-flex;align-items:center;gap:9px;padding:6px 18px;border-radius:100px;margin-bottom:28px;font-size:11px;font-weight:600;letter-spacing:0.1em';
        $("badgeDot").style.background=s.accent;
        $("badgeText").style.color=s.accent;
        $("badgeText").textContent=s.badge;
        $("h1Main").textContent=s.h1;
        $("h1Accent").textContent=s.h1a;
        $("h1Accent").style.color=s.accent;
        $("heroSub").textContent=s.sub;
        $("heroSupport").textContent=s.sup;
        $("ctaP").textContent=s.cta;
        $("ctaP").style.background=s.accent;
        $("ctaP").style.boxShadow='0 4px 20px '+s.accent+'35';
        $("ctaS").textContent=s.cta2;
        renderDash(s.dash,s.accent);

        // Dots
        var dh='';
        SL.forEach(function(_,i){
            if(i===cur){
                dh+='<span class="h-dot h-dot-on" style="background:'+s.accent+';cursor:pointer" data-idx="'+i+'"><span class="h-dot-prog '+(paused?'':'h-dot-prog-run')+'"></span></span>';
            } else {
                dh+='<span class="h-dot h-dot-off" style="cursor:pointer" data-idx="'+i+'"></span>';
            }
        });
        $("heroDots").innerHTML=dh;
        // Add click handlers to dots
        $("heroDots").querySelectorAll('.h-dot').forEach(function(dot){
            dot.addEventListener('click', function(){
                goTo(parseInt(this.getAttribute('data-idx')));
            });
        });

        // Labels
        var lh='';
        SL.forEach(function(sl,i){
            lh+='<span class="hero-label'+(i===cur?' act':'')+'" style="'+(i===cur?'color:'+s.accent:'')+';cursor:pointer" data-idx="'+i+'">'+sl.label+'</span>';
        });
        $("heroLabels").innerHTML=lh;
        $("heroLabels").querySelectorAll('.hero-label').forEach(function(lbl){
            lbl.addEventListener('click', function(){
                goTo(parseInt(this.getAttribute('data-idx')));
            });
        });

        $("heroCounter").textContent=String(cur+1).padStart(2,'0')+' / '+String(SL.length).padStart(2,'0');
    }

    function animIn(){
        $("heroText").className="hero-text active";
        $("heroVisual").className="hero-visual active";
    }

    function goTo(i){
        if(busy||i===cur)return;
        busy=true;
        $("heroText").className="hero-text exiting";
        $("heroVisual").className="hero-visual exiting";
        setTimeout(function(){
            cur=i;applySlide();animIn();busy=false;resetAuto();
        },380);
    }

    function nextSlide(){goTo((cur+1)%SL.length)}
    function prevSlide(){goTo((cur-1+SL.length)%SL.length)}

    function resetAuto(){
        clearInterval(timer);
        if(!paused) timer=setInterval(nextSlide,7000);
        applySlide();
    }

    document.addEventListener('DOMContentLoaded', function(){
        applySlide();
        animIn();
        timer=setInterval(nextSlide,7000);

        $("heroSection").addEventListener("mouseenter",function(){
            paused=true;clearInterval(timer);applySlide();
        });
        $("heroSection").addEventListener("mouseleave",function(){
            paused=false;resetAuto();
        });

        $("heroNext").addEventListener("click",nextSlide);
        $("heroPrev").addEventListener("click",prevSlide);

        document.addEventListener("keydown",function(e){
            if(e.key==="ArrowRight")nextSlide();
            if(e.key==="ArrowLeft")prevSlide();
        });
    });
})();
</script>
