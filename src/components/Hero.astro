<!-- ═══ HERO — Static Split Layout ═══ -->

<section class="hero" id="heroSection">
    <div class="hero-bg-grad"></div>
    <div class="hero-shapes" aria-hidden="true">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
        <div class="shape shape-4"></div>
        <div class="shape shape-5"></div>
        <div class="shape shape-6"></div>
        <div class="shape shape-7"></div>
        <div class="shape shape-8"></div>
    </div>

    <div class="hero-split">
        <!-- Left: Static content -->
        <div class="hero-left">
            <h1 class="hero-h1" id="hero-blur-text">The Intelligent Practice Management for Accountants</h1>
            <p class="hero-sub">VCPility is an AI powered growth and client acquisition engine built exclusively for Australian accounting, taxation and bookkeeping practices.</p>
            <p class="hero-support">No lock in contracts. Operational within days. One fixed monthly fee.</p>
            <div class="hero-ctas">
                <a href="/demo" class="cta-p" style="background:#c9a84c; box-shadow:0 4px 20px rgba(201,168,76,0.2);">Book a Growth Consultation</a>
                <span class="cta-or">or</span>
                <a href="/features" class="cta-s">Take a Tour</a>
            </div>
        </div>

        <!-- Right: Dashboard video -->
        <div class="hero-right">
            <div class="hero-video-frame">
                <video autoplay muted loop playsinline class="hero-demo-video">
                    <source src="/Recording 1.mp4" type="video/mp4">
                </video>
            </div>
        </div>
    </div>
</section>

<style is:global>
    .hero{position:relative;min-height:100vh;overflow:hidden}
    .hero-bg-grad{
        position:absolute;inset:0;z-index:0;
        background:radial-gradient(ellipse 120% 100% at 85% 20%, #2a2118 0%, #131010 40%, #080808 100%);
    }
    .hero-shapes{
        position:absolute;inset:0;z-index:1;pointer-events:none;overflow:hidden;
        perspective:800px;
    }
    .shape{
        position:absolute;
        border-radius:4px;
        transform-style:preserve-3d;
        will-change:transform;
    }
    /* Large hero block */
    .shape-1{
        width:200px;height:200px;
        bottom:8%;right:2%;
        background:linear-gradient(145deg, #c9a84c, #7a5a14);
        transform:rotateX(25deg) rotateY(-35deg) rotateZ(10deg);
        box-shadow:0 40px 80px rgba(0,0,0,0.6), inset 0 2px 0 rgba(255,255,255,0.15), inset -2px 0 0 rgba(255,255,255,0.05);
        animation:shapeFloat1 8s ease-in-out infinite;
    }
    /* Medium block, stacked */
    .shape-2{
        width:140px;height:140px;
        bottom:28%;right:10%;
        background:linear-gradient(145deg, #d4b05a, #8a6a1e);
        transform:rotateX(-15deg) rotateY(25deg) rotateZ(-5deg);
        box-shadow:0 30px 60px rgba(0,0,0,0.5), inset 0 2px 0 rgba(255,255,255,0.12);
        animation:shapeFloat2 10s ease-in-out infinite;
    }
    /* Tall block right edge */
    .shape-3{
        width:100px;height:160px;
        bottom:45%;right:0%;
        background:linear-gradient(145deg, #b8943e, #5e4010);
        transform:rotateX(30deg) rotateY(15deg) rotateZ(18deg);
        box-shadow:0 25px 50px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.08);
        animation:shapeFloat3 12s ease-in-out infinite;
    }
    /* Small accent block floating high */
    .shape-4{
        width:80px;height:80px;
        top:15%;right:5%;
        background:linear-gradient(145deg, #e2c06a, #a07828);
        transform:rotateX(-20deg) rotateY(-40deg) rotateZ(15deg);
        box-shadow:0 20px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.1);
        animation:shapeFloat1 14s ease-in-out infinite reverse;
    }
    /* Far left subtle block */
    .shape-5{
        width:60px;height:60px;
        bottom:20%;left:3%;
        background:linear-gradient(145deg, #c9a84c, #6e5018);
        opacity:0.4;
        transform:rotateX(40deg) rotateY(20deg) rotateZ(-10deg);
        box-shadow:0 15px 30px rgba(0,0,0,0.35);
        animation:shapeFloat2 9s ease-in-out infinite reverse;
    }
    /* Large block behind video */
    .shape-6{
        width:180px;height:120px;
        top:30%;right:15%;
        background:linear-gradient(145deg, #9a7520, #5a3a0a);
        transform:rotateX(20deg) rotateY(-25deg) rotateZ(5deg);
        box-shadow:0 35px 70px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.06);
        animation:shapeFloat3 11s ease-in-out infinite reverse;
        opacity:0.7;
    }
    /* Tiny accent top left */
    .shape-7{
        width:40px;height:40px;
        top:25%;left:8%;
        background:linear-gradient(145deg, #d4b05a, #8a6a1e);
        transform:rotateX(-30deg) rotateY(35deg) rotateZ(-12deg);
        box-shadow:0 10px 20px rgba(0,0,0,0.3);
        animation:shapeFloat1 16s ease-in-out infinite;
        opacity:0.3;
    }
    /* Medium bottom center */
    .shape-8{
        width:90px;height:90px;
        bottom:5%;right:35%;
        background:linear-gradient(145deg, #c9a84c, #7a5a14);
        transform:rotateX(35deg) rotateY(-20deg) rotateZ(8deg);
        box-shadow:0 20px 45px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.08);
        animation:shapeFloat2 13s ease-in-out infinite;
        opacity:0.5;
    }
    @keyframes shapeFloat1{
        0%,100%{transform:rotateX(25deg) rotateY(-35deg) rotateZ(10deg) translateY(0)}
        50%{transform:rotateX(30deg) rotateY(-30deg) rotateZ(12deg) translateY(-20px)}
    }
    @keyframes shapeFloat2{
        0%,100%{transform:rotateX(-15deg) rotateY(25deg) rotateZ(-5deg) translateY(0)}
        50%{transform:rotateX(-10deg) rotateY(30deg) rotateZ(-3deg) translateY(-15px)}
    }
    @keyframes shapeFloat3{
        0%,100%{transform:rotateX(35deg) rotateY(15deg) rotateZ(20deg) translateY(0)}
        50%{transform:rotateX(40deg) rotateY(10deg) rotateZ(22deg) translateY(-25px)}
    }

    .hero-split{
        position:relative;z-index:3;max-width:1340px;margin:0 auto;
        display:grid;grid-template-columns:1fr 1fr;align-items:center;
        padding:140px 52px 100px;gap:48px;min-height:100vh;
    }

    .hero-left{position:relative;}

    .hero-badge{
        display:inline-flex;align-items:center;gap:9px;
        padding:6px 18px;border-radius:100px;margin-bottom:28px;
        font-size:11px;font-weight:600;letter-spacing:0.1em;
        font-family:'Space Grotesk',sans-serif;
    }
    .hero-badge-dot{width:6px;height:6px;border-radius:50%;animation:heroPulse 2.5s ease-in-out infinite}
    @keyframes heroPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.6;transform:scale(1.4)}}

    .hero-h1{
        font-family:'Fraunces',Georgia,serif;font-size:clamp(32px,4vw,52px);font-weight:400;
        line-height:1.08;color:#F8FAFC;margin-bottom:22px;
        letter-spacing:-0.02em;max-width:640px;
    }
    .hero-h1 em{font-style:normal;}
    .hero-sub{font-size:16px;line-height:1.72;color:rgba(226,232,240,0.6);max-width:520px;margin-bottom:10px;font-family:'Space Grotesk',sans-serif}
    .hero-support{font-size:13px;color:rgba(226,232,240,0.35);margin-bottom:36px;font-family:'Space Grotesk',sans-serif}
    .hero-ctas{display:flex;gap:14px;flex-wrap:wrap;align-items:center}
    .cta-or{font-size:14px;color:rgba(255,255,255,0.25);font-family:'Space Grotesk',sans-serif}
    .cta-p{
        display:inline-block;padding:15px 34px;border-radius:9px;border:none;
        color:#fff;font-size:15px;font-weight:600;font-family:'Space Grotesk',sans-serif;
        cursor:pointer;transition:all 0.35s cubic-bezier(0.22,1,0.36,1);text-decoration:none;
    }
    .cta-p:hover{transform:translateY(-2px);filter:brightness(1.12)}
    .cta-s{
        display:inline-block;padding:15px 28px;border-radius:9px;
        border:1px solid rgba(255,255,255,0.15);
        background:transparent;color:rgba(226,232,240,0.7);
        font-size:15px;font-weight:500;font-family:'Space Grotesk',sans-serif;cursor:pointer;transition:all 0.3s;text-decoration:none;
    }
    .cta-s:hover{background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.3)}

    .hero-right{
        display:flex;align-items:center;justify-content:flex-end;
    }
    .hero-video-frame{
        width:100%;max-width:480px;
        aspect-ratio:4/3;
        border-radius:14px;overflow:hidden;
        border:1px solid rgba(201,168,76,0.2);
        box-shadow:0 30px 80px rgba(0,0,0,0.5), 0 0 40px rgba(201,168,76,0.06);
        background:#111;
        margin-left:auto;
    }
    .hero-demo-video{
        width:100%;height:100%;display:block;object-fit:cover;
    }

    @media(max-width:1024px){
        .hero-split{grid-template-columns:1fr;padding:120px 28px 80px;gap:40px}
        .hero-h1{font-size:36px}
        .hero-right{max-width:480px;margin:0 auto}
    }
    @media(max-width:600px){
        .hero-split{padding:100px 20px 60px}
    }
</style>

<script is:inline>
(function(){
    // 3D Gold cubes animation
    function initCubes(){
        var c=document.getElementById('heroCubes');
        if(!c)return;
        var ctx=c.getContext('2d');
        var W,H;
        function resize(){W=c.width=c.offsetWidth;H=c.height=c.offsetHeight;}
        resize();window.addEventListener('resize',resize);

        var CONNECT_DIST=160;
        var particles=[];
        var count=50;
        for(var i=0;i<count;i++){
            particles.push({
                x:Math.random()*W,
                y:Math.random()*H,
                vx:(Math.random()-0.5)*0.4,
                vy:(Math.random()-0.5)*0.4,
                r:1.5+Math.random()*2,
                phase:Math.random()*Math.PI*2
            });
        }

        var time=0;
        function frame(){
            ctx.clearRect(0,0,W,H);
            time+=0.01;

            // Update positions
            particles.forEach(function(p){
                p.x+=p.vx;
                p.y+=p.vy;
                if(p.x<0){p.x=W;}
                if(p.x>W){p.x=0;}
                if(p.y<0){p.y=H;}
                if(p.y>H){p.y=0;}
            });

            // Draw connections
            for(var i=0;i<count;i++){
                for(var j=i+1;j<count;j++){
                    var dx=particles[i].x-particles[j].x;
                    var dy=particles[i].y-particles[j].y;
                    var dist=Math.sqrt(dx*dx+dy*dy);
                    if(dist<CONNECT_DIST){
                        var alpha=0.08*(1-dist/CONNECT_DIST);
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x,particles[i].y);
                        ctx.lineTo(particles[j].x,particles[j].y);
                        ctx.strokeStyle='rgba(201,168,76,'+alpha+')';
                        ctx.lineWidth=0.8;
                        ctx.stroke();
                    }
                }
            }

            // Draw particles
            particles.forEach(function(p){
                var pulse=0.6+0.4*Math.sin(time*2+p.phase);
                // Glow
                ctx.beginPath();
                ctx.arc(p.x,p.y,p.r*4,0,Math.PI*2);
                ctx.fillStyle='rgba(201,168,76,'+(0.03*pulse)+')';
                ctx.fill();
                // Dot
                ctx.beginPath();
                ctx.arc(p.x,p.y,p.r*pulse,0,Math.PI*2);
                ctx.fillStyle='rgba(201,168,76,'+(0.25*pulse)+')';
                ctx.fill();
            });

            requestAnimationFrame(frame);
        }
        frame();
    }

    function initBlurText(){
        var el = document.getElementById('hero-blur-text');
        if (!el) return;
        var text = el.textContent.trim();
        var accentWords = ['Intelligent', 'Accountants'];
        // Prevent Accountants from breaking
        var noBreakWords = ['Accountants'];
        el.innerHTML = '';
        var words = text.split(' ');
        words.forEach(function(word, wi) {
            var isAccent = accentWords.indexOf(word) !== -1;
            var isNoBreak = noBreakWords.indexOf(word) !== -1;
            if (isNoBreak) {
                var wrapper = document.createElement('span');
                wrapper.style.whiteSpace = 'nowrap';
                wrapper.style.display = 'inline-block';
                for (var i = 0; i < word.length; i++) {
                    var span = document.createElement('span');
                    span.style.display = 'inline-block';
                    span.style.filter = 'blur(10px)';
                    span.style.opacity = '0';
                    span.style.transition = 'filter 0.5s ease, opacity 0.5s ease';
                    span.style.transitionDelay = (wi * 80 + i * 35) + 'ms';
                    if (isAccent) span.style.color = '#c9a84c';
                    span.textContent = word[i];
                    wrapper.appendChild(span);
                }
                el.appendChild(wrapper);
            } else {
                for (var i = 0; i < word.length; i++) {
                    var span = document.createElement('span');
                    span.style.display = 'inline-block';
                    span.style.filter = 'blur(10px)';
                    span.style.opacity = '0';
                    span.style.transition = 'filter 0.5s ease, opacity 0.5s ease';
                    span.style.transitionDelay = (wi * 80 + i * 35) + 'ms';
                    if (isAccent) span.style.color = '#c9a84c';
                    span.textContent = word[i];
                    el.appendChild(span);
                }
            }
            if (wi < words.length - 1) {
                var space = document.createElement('span');
                space.innerHTML = '&nbsp;';
                space.style.display = 'inline-block';
                el.appendChild(space);
            }
        });
        // Trigger after short delay
        setTimeout(function(){
            var chars = el.querySelectorAll('span');
            chars.forEach(function(ch){
                ch.style.filter = 'blur(0)';
                ch.style.opacity = '1';
            });
        }, 200);
    }

    document.addEventListener('DOMContentLoaded', function(){ initBlurText(); });
})();
</script>
