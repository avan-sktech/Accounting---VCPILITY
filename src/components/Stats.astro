<!-- ═══ STATS — "The Evidence Wall" ═══ -->
<section class="py-20 px-6 lg:px-10">
    <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
            <div class="stat-card rounded-[4px] p-8 text-center reveal">
                <div class="big-num count-up" data-target="14" data-suffix=" days" style="color:var(--text-bright)">0</div>
                <div class="text-xs font-semibold tracking-widest uppercase mt-2" style="color:var(--text-muted)">Debtor Days</div>
                <div class="mt-4 h-1 w-10 mx-auto rounded-full" style="background:rgba(13,17,23,0.1)"></div>
            </div>
            <div class="stat-card rounded-[4px] p-8 text-center reveal reveal-d1">
                <div class="big-num count-up" data-target="3.1" data-suffix="×" style="color:var(--gold)">0</div>
                <div class="text-xs font-semibold tracking-widest uppercase mt-2" style="color:var(--text-muted)">Revenue Per Client</div>
                <div class="mt-4 h-1 w-14 mx-auto rounded-full" style="background:rgba(201,168,76,0.4)"></div>
            </div>
            <div class="stat-card rounded-[4px] p-8 text-center reveal reveal-d2">
                <div class="big-num count-up" data-target="100" data-suffix="%" style="color:#2eb8a0">0</div>
                <div class="text-xs font-semibold tracking-widest uppercase mt-2" style="color:var(--text-muted)">On-Time BAS & Payroll</div>
                <div class="mt-4 h-1 w-8 mx-auto rounded-full" style="background:rgba(46,184,160,0.4)"></div>
            </div>
            <div class="stat-card rounded-[4px] p-8 text-center reveal reveal-d3">
                <div class="big-num count-up" data-target="6.3" data-suffix=" months" style="color:#a89fd4">0</div>
                <div class="text-xs font-semibold tracking-widest uppercase mt-2" style="color:var(--text-muted)">Cash Runway</div>
                <div class="mt-4 h-1 w-12 mx-auto rounded-full" style="background:rgba(129,140,248,0.4)"></div>
            </div>
        </div>
    </div>
</section>
