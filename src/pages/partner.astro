---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Meet Your Growth Partner | VCPility — Accounting OS">
    <Nav />
    <div class="pt-24">

    <section class="partner-page py-20 px-6 lg:px-10">
        <div class="max-w-4xl mx-auto">

            <!-- Header -->
            <p class="section-label text-center mb-3" style="color:#c9a84c;">Built for accounting practices</p>
            <h1 class="syne text-center font-bold leading-tight mb-5" style="color:#f0ead6; font-size:clamp(2.2rem,5vw,3.4rem);">Growth support that actually understands your practice</h1>
            <p class="text-center text-base leading-relaxed mb-5 max-w-2xl mx-auto" style="color:#9da8b8;">The only growth platform built exclusively for Australian accountants — by a CPA-qualified team with real experience inside the profession.</p>
            <div class="mx-auto mb-10" style="width:36px; height:2px; background:#c9a84c; border-radius:2px;"></div>

            <!-- Stats Row -->
            <div class="partner-stats mb-10">
                <div class="partner-stat">
                    <span class="partner-stat-num syne">100%</span>
                    <span class="partner-stat-label">Accounting practices only</span>
                </div>
                <div class="partner-stat">
                    <span class="partner-stat-num syne">CPA</span>
                    <span class="partner-stat-label">Qualified team</span>
                </div>
                <div class="partner-stat">
                    <span class="partner-stat-num syne">AU</span>
                    <span class="partner-stat-label">Local support team</span>
                </div>
                <div class="partner-stat">
                    <span class="partner-stat-num syne">$0</span>
                    <span class="partner-stat-label">No setup fees</span>
                </div>
            </div>

            <!-- Not DIY -->
            <div class="partner-not-diy mb-8">
                <div class="partner-shield">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                    <p class="text-base font-semibold mb-2" style="color:#f0ead6;">This is not a system you figure out yourself.</p>
                    <p class="text-sm leading-relaxed" style="color:#8a7d6a;">You will not be handed a login and left alone. VCPility comes with a <strong style="color:#d4b96a;">fully supported Australian team</strong> who onboards your practice, manages the platform, and drives results alongside you. <strong style="color:#d4b96a;">You focus on your clients — we run the growth engine.</strong></p>
                </div>
            </div>

            <!-- CPA Credential -->
            <div class="partner-cpa mb-10">
                <div class="partner-avatar syne">SS</div>
                <div style="flex:1;">
                    <div class="partner-cpa-tag">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1l1.5 3h3l-2.5 2 1 3L6 7.5 3 9l1-3L1.5 4h3z" fill="#B8860B"/></svg>
                        CPA Qualified
                    </div>
                    <p class="text-base font-semibold" style="color:#f0ead6;">Sheryl Sani CPA — Head of Practice Strategy, VCPility</p>
                    <p class="text-sm mb-2" style="color:#6b7a8d;">CPA · Former Deloitte Australia · Former KPMG · Accounting Industry Specialist</p>
                    <p class="text-sm leading-relaxed" style="color:#9da8b8;">Sheryl's Big 4 background across Deloitte Australia and KPMG gives VCPility a deep understanding of how accounting practices operate and what it takes to build client trust in a regulated profession. Every strategy we build is grounded in real accounting industry experience.</p>
                </div>
            </div>

            <!-- Two Column: Pillars + Proof -->
            <div class="partner-two-col mb-10">
                <!-- Pillars -->
                <div class="partner-pillars">
                    <div class="partner-pillar">
                        <p class="text-sm font-semibold mb-1" style="color:#f0ead6;">Accounting-native</p>
                        <p class="text-sm leading-relaxed" style="color:#7a8899;">Built around how accounting practices operate — not a generic marketing tool.</p>
                    </div>
                    <div class="partner-pillar">
                        <p class="text-sm font-semibold mb-1" style="color:#f0ead6;">Fully managed</p>
                        <p class="text-sm leading-relaxed" style="color:#7a8899;">Your local team handles setup, execution, and ongoing optimisation.</p>
                    </div>
                    <div class="partner-pillar">
                        <p class="text-sm font-semibold mb-1" style="color:#f0ead6;">Compliance-aware</p>
                        <p class="text-sm leading-relaxed" style="color:#7a8899;">All campaigns are designed with professional ethics and industry standards in mind.</p>
                    </div>
                    <div class="partner-pillar">
                        <p class="text-sm font-semibold mb-1" style="color:#f0ead6;">Fixed monthly fee</p>
                        <p class="text-sm leading-relaxed" style="color:#7a8899;">No markups, no hidden costs. One predictable investment.</p>
                    </div>
                </div>

                <!-- Proof + Risk -->
                <div class="partner-right-col">
                    <div class="partner-proof">
                        <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color:#c9a84c;">Included from day one</p>
                        <div class="partner-proof-item">
                            <div class="partner-check"><svg width="8" height="8" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 3" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                            <span>Dedicated onboarding specialist</span>
                        </div>
                        <div class="partner-proof-item">
                            <div class="partner-check"><svg width="8" height="8" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 3" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                            <span>Done-for-you content and campaigns</span>
                        </div>
                        <div class="partner-proof-item">
                            <div class="partner-check"><svg width="8" height="8" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 3" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                            <span>Custom AI trained on your practice</span>
                        </div>
                        <div class="partner-proof-item">
                            <div class="partner-check"><svg width="8" height="8" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 3" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                            <span>Lead generation and nurture sequences</span>
                        </div>
                        <div class="partner-proof-item">
                            <div class="partner-check"><svg width="8" height="8" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 3" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                            <span>Monthly strategy and review calls</span>
                        </div>
                    </div>
                    <div class="partner-risk">
                        <p class="text-sm font-semibold mb-2" style="color:#f0ead6;">Start without risk.</p>
                        <div class="partner-risk-tags">
                            <span class="partner-risk-tag">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#C9A84C" stroke-width="1.2"/><path d="M5 8l2 2 4-4" stroke="#C9A84C" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                30-day pilot
                            </span>
                            <span class="partner-risk-tag">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#C9A84C" stroke-width="1.2"/><path d="M5 8l2 2 4-4" stroke="#C9A84C" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                No lock-in
                            </span>
                            <span class="partner-risk-tag">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#C9A84C" stroke-width="1.2"/><path d="M5 8l2 2 4-4" stroke="#C9A84C" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                No setup fee
                            </span>
                            <span class="partner-risk-tag">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#C9A84C" stroke-width="1.2"/><path d="M5 8l2 2 4-4" stroke="#C9A84C" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Cancel any time
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CTA -->
            <div class="text-center mb-8">
                <a href="/demo" class="btn-primary inline-block px-10 py-4 rounded-[3px] text-base">Book a strategy call →</a>
                <p class="text-sm mt-3" style="color:#6b7a8d;">30 minutes — no scripts, no pressure, no obligation.</p>
            </div>

            <!-- Disclaimer -->
            <p class="text-center text-xs leading-relaxed pt-6" style="color:#4a5568; border-top:1px solid rgba(201,168,76,0.1);">VCPility is a marketing and growth platform for accounting practices. It does not provide financial, tax, legal, or professional accounting advice. Sheryl Sani's professional background is referenced as an indicator of industry understanding only — not as an offer of regulated professional services. Practice data is handled in accordance with our Privacy Policy and is never shared with third parties.</p>

        </div>
    </section>

    </div>
    <Footer />
</Layout>

<style>
    .partner-page { background: #0d1117; }

    .partner-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: rgba(201,168,76,0.15);
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid rgba(201,168,76,0.15);
    }
    .partner-stat {
        background: #0b0f14;
        padding: 16px 12px;
        text-align: center;
    }
    .partner-stat-num {
        display: block;
        font-size: 2rem;
        font-weight: 900;
        color: #c9a84c;
        line-height: 1;
        margin-bottom: 6px;
    }
    .partner-stat-label {
        font-size: 0.85rem;
        color: #6b7a8d;
        line-height: 1.3;
        font-weight: 500;
    }

    .partner-not-diy {
        background: #161b22;
        border-radius: 12px;
        padding: 20px 24px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
        border: 1px solid rgba(201,168,76,0.1);
    }
    .partner-shield {
        flex-shrink: 0;
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .partner-cpa {
        background: #161b22;
        border: 1px solid rgba(201,168,76,0.1);
        border-radius: 12px;
        padding: 20px 24px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
    }
    .partner-avatar {
        flex-shrink: 0;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: rgba(201,168,76,0.1);
        border: 2px solid #c9a84c;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 700;
        color: #c9a84c;
    }
    .partner-cpa-tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(201,168,76,0.1);
        border: 1px solid rgba(201,168,76,0.25);
        border-radius: 5px;
        padding: 4px 10px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #c9a84c;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .partner-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .partner-pillars {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }
    .partner-pillar {
        background: #161b22;
        border: 1px solid rgba(201,168,76,0.08);
        border-radius: 10px;
        padding: 18px 20px;
        position: relative;
        overflow: hidden;
    }
    .partner-pillar::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: #c9a84c;
    }

    .partner-right-col {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .partner-proof {
        background: rgba(201,168,76,0.04);
        border: 1px solid rgba(201,168,76,0.1);
        border-radius: 10px;
        padding: 14px 16px;
    }
    .partner-proof-item {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 8px;
        font-size: 0.9rem;
        color: #9da8b8;
        font-weight: 500;
    }
    .partner-check {
        flex-shrink: 0;
        width: 16px;
        height: 16px;
        background: #c9a84c;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .partner-risk {
        background: #161b22;
        border-radius: 10px;
        padding: 14px 16px;
        border: 1px solid rgba(201,168,76,0.08);
    }
    .partner-risk-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .partner-risk-tag {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        color: #d4b96a;
        font-weight: 500;
    }

    @media (max-width: 768px) {
        .partner-stats { grid-template-columns: repeat(2, 1fr); }
        .partner-two-col { grid-template-columns: 1fr; }
        .partner-pillars { grid-template-columns: 1fr; }
        .partner-not-diy, .partner-cpa { flex-direction: column; }
    }
</style>
