---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustCompact from '../components/TrustCompact.astro';
import Stats from '../components/Stats.astro';
import Problem from '../components/Problem.astro';
import Lifecycle from '../components/Lifecycle.astro';
import EraShift from '../components/EraShift.astro';
import Integrations from '../components/Integrations.astro';
import SecuritySection from '../components/SecuritySection.astro';
import GrowthPartner from '../components/GrowthPartner.astro';
import AIAgents from '../components/AIAgents.astro';
import PlatformOverview from '../components/PlatformOverview.astro';
import DemoForm from '../components/DemoForm.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
    <Nav />
    <Hero />
    <TrustCompact />
    <hr class="hr-grad">
    <Stats />
    <hr class="hr-grad">
    <Problem />
    <EraShift />
    <Lifecycle />
    <Integrations />
    <hr class="hr-grad">
    <SecuritySection />
    <hr class="hr-grad">
    <GrowthPartner />
    <hr class="hr-grad">
    <AIAgents />
    <hr class="hr-grad">
    <PlatformOverview />
    <hr class="hr-grad">
    <DemoForm />
    <FAQ />
    <Footer />
</Layout>
