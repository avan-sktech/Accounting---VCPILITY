---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import Lifecycle from '../components/Lifecycle.astro';
import EraShift from '../components/EraShift.astro';
import Integrations from '../components/Integrations.astro';
import ToolsGrid from '../components/ToolsGrid.astro';
import GrowthPartner from '../components/GrowthPartner.astro';
import AIAgents from '../components/AIAgents.astro';
import PlatformOverview from '../components/PlatformOverview.astro';
import DemoForm from '../components/DemoForm.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
    <Nav />
    <Hero />
    <StatsBar />
    <EraShift />
    <Lifecycle />
    <Integrations />
    <hr class="hr-grad">
    <ToolsGrid />
    <hr class="hr-grad">
    <GrowthPartner />
    <hr class="hr-grad">
    <AIAgents />
    <hr class="hr-grad">
    <PlatformOverview />
    <hr class="hr-grad">
    <DemoForm />
    <FAQ />
    <Footer />
</Layout>
