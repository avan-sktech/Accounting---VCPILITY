        background: rgba(201,168,76,0.04);
    }
    .eval-price-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.6rem;
    }
    .eval-price-amount {
        font-family: 'Fraunces', serif;
        font-size: clamp(2rem, 4vw, 2.8rem);
