</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const tabs = document.querySelectorAll('.eval-plan-tab');
        const panelManaged = document.getElementById('panel-managed');
        const panelDiy = document.getElementById('panel-diy');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');

                const selected = tab.getAttribute('data-tab');
                if (selected === 'managed') {
                    panelManaged.style.display = 'block';
                    panelDiy.style.display = 'none';
                } else {
                    panelManaged.style.display = 'none';
                    panelDiy.style.display = 'block';
                }
            });
        });
    });
</script>
