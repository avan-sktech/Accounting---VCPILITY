        margin-bottom: 0.6rem;
    }
    .eval-price-per {
        font-size: 0.9rem;
        font-weight: 400;
        opacity: 0.7;
    }
    .eval-price-desc {
        font-size: 0.8rem;
        line-height: 1.5;
        color: var(--text-muted);
    }

    /* ═══ MANAGED FEATURES LIST ═══ */
    .eval-managed-features {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem 1.5rem;
    }
    .eval-managed-item {
        font-size: 0.82rem;
