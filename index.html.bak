<!-- ═══ JAVASCRIPT ═══ -->
<script>
// Scroll reveal (IntersectionObserver)
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
        }
    });
}, { threshold: 0.05, rootMargin: '50px 0px 0px 0px' });
// Small delay ensures elements already in viewport get observed correctly
requestAnimationFrame(() => {
    reveals.forEach(el => observer.observe(el));
});

// Count-up animation
const counters = document.querySelectorAll('.count-up');
const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            const el = entry.target;
            const target = parseFloat(el.dataset.target);
            const suffix = el.dataset.suffix || '';
            const decimals = el.dataset.target.includes('.') ? el.dataset.target.split('.')[1].length : 0;
            const duration = 1500;
            const start = performance.now();
            function tick(now) {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = (target * eased).toFixed(decimals) + suffix;
                if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
            counterObserver.unobserve(el);
        }
    });
}, { threshold: 0.5 });
counters.forEach(el => counterObserver.observe(el));

// Pricing toggle
function togglePricing(btn) {
    const features = btn.nextElementSibling;
    btn.classList.toggle('open');
    features.classList.toggle('open');
}

// Mobile timeline tap-to-reveal
if (window.innerWidth <= 768) {
    document.querySelectorAll('.timeline-node').forEach(node => {
        node.addEventListener('click', () => {
            const wasActive = node.classList.contains('active');
            document.querySelectorAll('.timeline-node').forEach(n => n.classList.remove('active'));
            if (!wasActive) node.classList.add('active');
        });
    });
}

// Logo Loop — smooth rAF-driven marquee (React Bits style)
(function() {
    const tracks = document.querySelectorAll('.marquee-track');
    tracks.forEach(track => {
        const isReverse = track.dataset.reverse === 'true';
        const baseSpeed = parseFloat(track.dataset.speed) || 0.5;
        let offset = 0;
        let currentSpeed = baseSpeed;
        let targetSpeed = baseSpeed;
        let halfWidth = 0;

        // Count how many duplicate sets: look for comment nodes or use data attribute
        const copies = parseInt(track.dataset.copies) || 2;
        function calcWidth() {
            halfWidth = track.scrollWidth / copies;
        }
        calcWidth();
        setTimeout(calcWidth, 1000);
        setTimeout(calcWidth, 3000);

        const wrap = track.parentElement;
        wrap.addEventListener('mouseenter', () => { targetSpeed = baseSpeed * 0.15; });
        wrap.addEventListener('mouseleave', () => { targetSpeed = baseSpeed; });

        function update() {
            if (halfWidth === 0) { calcWidth(); }
            currentSpeed += (targetSpeed - currentSpeed) * 0.05;
            offset += isReverse ? -currentSpeed : currentSpeed;
            if (!isReverse && offset >= halfWidth) { offset -= halfWidth; }
            if (isReverse && offset <= -halfWidth) { offset += halfWidth; }
            track.style.transform = 'translate3d(' + (-offset) + 'px, 0, 0)';
            requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
    });
})();

// GSAP ScrollTrigger — services section scroll animations
gsap.registerPlugin(ScrollTrigger);

gsap.from('.gsap-label', {
    scrollTrigger: { trigger: '.gsap-label', start: 'top 85%' },
    opacity: 0, y: 30, duration: 0.8, ease: 'power3.out'
});

gsap.from('.gsap-heading', {
    scrollTrigger: { trigger: '.gsap-heading', start: 'top 85%' },
    opacity: 0, y: 50, duration: 1, ease: 'power3.out', delay: 0.2
});

gsap.utils.toArray('.gsap-rule, .gsap-divider').forEach(rule => {
    gsap.to(rule, {
        scrollTrigger: { trigger: rule, start: 'top 90%' },
        width: '100%', duration: 1.2, ease: 'power2.inOut'
    });
});

gsap.utils.toArray('.gsap-panel').forEach((panel) => {
    gsap.to(panel, {
        scrollTrigger: { trigger: panel, start: 'top 80%' },
        opacity: 1, y: 0, duration: 0.9, ease: 'power3.out'
    });

    const children = panel.querySelectorAll('h3, p, .flex, span');
    gsap.from(children, {
        scrollTrigger: { trigger: panel, start: 'top 80%' },
        opacity: 0, y: 25, stagger: 0.08, duration: 0.6, ease: 'power2.out', delay: 0.3
    });

    const img = panel.querySelector('img');
    if (img) {
        gsap.from(img, {
            scrollTrigger: { trigger: panel, start: 'top 85%', end: 'bottom 20%', scrub: 1 },
            scale: 1.15, ease: 'none'
        });
    }
});
</script>

<!-- END OF SCRIPTS -->
</body>
</html>
